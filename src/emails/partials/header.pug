table.header(role="presentation", width="100%", cellspacing="0", cellpadding="0", border="0")
  tr
    td(style="width: 40px; padding-right: 15px; vertical-align: top;")
      .logo(style="width:40px; height:40px; border-radius:6px; background:#1270d4; font-size:18px; font-weight:700; color:#fff; display:block; line-height:40px; text-align:center;")
        | SSCA
    td(style="vertical-align: top;")
      p.title(style="font-size:20px; font-weight:700; margin:0; color:#333") Resumen de Marcaciones Diarias
      p.subtitle(style="margin:2px 0 0 0; font-size:13px; color:#888") Datos consolidados generados automáticamente por el sistema.
    td(style="text-align:right; width: 120px; vertical-align: top;")
      p.muted(style="margin:0;") Fecha
      p(style="margin:0; font-size:14px; font-weight:700; color:#444") #{fecha}